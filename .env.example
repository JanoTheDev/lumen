# AI Overlay — API Keys
# Copy this file to .env and fill in ONE of the following.
# .env is gitignored and will never be committed.

# Option A — Anthropic (Claude Sonnet 4.6, recommended)
ANTHROPIC_API_KEY=

# Option B — OpenAI (GPT-4o, use if you don't have Anthropic access)
OPENAI_API_KEY=

# The app uses whichever key is present. If both are set, Anthropic wins.
